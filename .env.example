# SAP Sage — API Keys
# Copy this file to .env and fill in your keys

# Groq (Free, Fastest) — console.groq.com → API Keys (no credit card)
VITE_GROQ_API_KEY=your_groq_key_here

# Anthropic Claude — console.anthropic.com → API Keys (pay-as-you-go)
VITE_ANTHROPIC_API_KEY=your_anthropic_key_here

# Together AI ($5 free credit) — api.together.ai → Settings → API Keys
VITE_TOGETHER_API_KEY=your_together_key_here

# Ollama — no key needed, just run: OLLAMA_ORIGINS="*" ollama serve
